{
  "name": "Weather_App",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "20": "^3.1.9",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "express": "^4",
    "@cap-js/sqlite": "^2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-weather_app": "cds watch --open weatherapp/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/weather_app"
  ],
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "model": [
          "srv",
          "db"
        ]
      },
      "html5-repo": true,
      "[production]": {
        "auth": "xsuaa"
      }
    }
  }
}
