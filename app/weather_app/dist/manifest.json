{
	"_version": "1.81.0",
	"sap.app": {
		"id": "weatherapp",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				""
			]
		},
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:fpm",
			"version": "1.20.2",
			"toolsId": "03e65046-7700-44b5-ac17-cd98065b61c0"
		},
		"dataSources": {
			"mainService": {
				"uri": "/odata/v4/weather/",
				"type": "OData",
				"settings": {
					"annotations": [],
					"odataVersion": "4.0"
				}
			}
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.145.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.fe.core": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "weatherapp.i18n.i18n",
					"supportedLocales": [
						""
					]
				}
			},
			"": {
				"dataSource": "mainService",
				"preload": true,
				"settings": {
					"operationMode": "Server",
					"autoExpandSelect": true,
					"earlyRequests": true
				}
			},
			"@i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"uri": "i18n/i18n.properties",
				"settings": {
					"supportedLocales": [
						""
					]
				}
			}
		},
		"resources": {
			"css": []
		},
		"routing": {
			"config": {},
			"routes": [
				{
					"name": "WeatherOverviewResultMain",
					"pattern": ":?query:",
					"target": "WeatherOverviewResultMain"
				}
			],
			"targets": {
				"WeatherOverviewResultMain": {
					"type": "Component",
					"id": "WeatherOverviewResultMain",
					"name": "sap.fe.core.fpm",
					"options": {
						"settings": {
							"navigation": {},
							"contextPath": "/WeatherOverviewResult",
							"viewName": "weatherapp.ext.main.Main"
						}
					}
				}
			}
		},
		"flexBundle": false
	},
	"sap.fe": {
		"app": {
			"enableLazyLoading": true
		}
	},
	"sap.fiori": {}
}