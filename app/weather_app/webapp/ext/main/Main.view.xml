<mvc:View xmlns:core="sap.ui.core"     xmlns:mvc="sap.ui.core.mvc" 
    xmlns="sap.m" xmlns:macros="sap.fe.macros" 
    xmlns:html="http://www.w3.org/1999/xhtml" 
    controllerName="weatherapp.ext.main.Main"    
    xmlns:f="sap.f"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
<macros:Page id="Page">

        <!--Søgefelt-->
      <SearchField
        id="citySearch"
        placeholder="Search city..."
        search=".onSearchCity">

        <SuggestionItem id="_IDGenSuggestionItem" text="{City}" />
      </SearchField>

        <!--Vejr data felterne kommer fra annotations.cds-->
      <macros:Form id="WeatherForm" metaPath="@UI.FieldGroup#General" />

        <!--Graf-->
      <HBox id="_IDGenHBox5" justifyContent="Center" class="sapUiMediumMarginBottom" width="100%">  
        <f:Card id="_IDGenCard1" class="sapUiTinyMarginBottom">
          <f:content>
            <VBox id="_IDGenVBox1" class="sapUiMediumMarginTop" alignItems="Center" width="100%">

              <viz:VizFrame id="idVizFrame" uiConfig="{applicationSet:'fiori'}"
                height='600px' width="1200px" vizType='combination' vizProperties='{
                    "title": { "text": "Weather next 24 hours" },
                    "valueAxis": { "title": { "visible": true, "text": "Values" } },
                    "categoryAxis": { "title": { "visible": true, "text": "Hour" } },
                    "plotArea": { "gridline": { "visible": true },
                    "dataLabel": { "visible": true }}
                }'>
                <viz:dataset>
                  <viz.data:FlattenedDataset id="_IDGenFlattenedDataset1" data="{chart>/data}">
                    <viz.data:dimensions>
                      <viz.data:DimensionDefinition id="_IDGenDimensionDefinition" name="Hour" value="{hour}" />
                    </viz.data:dimensions>
                      <viz.data:measures>
                        <viz.data:MeasureDefinition id="_IDGenMeasureDefinition" name="Temperature" value="{temperature}" />
                        <viz.data:MeasureDefinition id="_IDGenMeasureDefinition1" name="Precipitation" value="{rain}" />
                      </viz.data:measures>
                    </viz.data:FlattenedDataset>
                </viz:dataset>
                <viz:feeds>
                  <viz.feeds:FeedItem id="_IDGenFeedItem1" uid="valueAxis" type="Measure" values="Precipitation,Temperature" />
                  <viz.feeds:FeedItem id="_IDGenFeedItem2" uid="categoryAxis" type="Dimension" values="Hour" />
                </viz:feeds>
              </viz:VizFrame>

              <!--Graf windSpeed-->
              <viz:VizFrame
                id="windChart"
                uiConfig="{applicationSet:'fiori'}"
                height="250px"
                width="1200px"
                vizType="line"
                vizProperties='{
                    "title": { "text": "Wind speed" },
                    "legend": { "visible": false },
                    "valueAxis": { "title": { "visible": true, "text": "m/s" }},
                    "plotArea": { "gridline": { "visible": true },
                    "dataLabel": { "visible": true }}
                }'>
                <viz:dataset>
                    <viz.data:FlattenedDataset id="_IDGenFlattenedDataset2" data="{chart>/data}">
                        <viz.data:dimensions>
                            <viz.data:DimensionDefinition id="_IDGenDimensionDefinition1" name="Hour" value="{hour}" />
                        </viz.data:dimensions>
                        <viz.data:measures>
                            <viz.data:MeasureDefinition id="_IDGenMeasureDefinition2" name="Wind" value="{windSpeed}" />
                        </viz.data:measures>
                    </viz.data:FlattenedDataset>
                </viz:dataset>
                <viz:feeds>
                    <viz.feeds:FeedItem id="_IDGenFeedItem" uid="valueAxis" type="Measure" values="Wind"/>
                    <viz.feeds:FeedItem id="_IDGenFeedItem3" uid="categoryAxis" type="Dimension" values="Hour"/>
                </viz:feeds>
              </viz:VizFrame>
            </VBox>
          </f:content>
        </f:Card>
      </HBox>
    </macros:Page>

</mvc:View>